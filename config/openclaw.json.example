  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "9571bdaf4e5ce27cf257faef30160a887c664d61d41f5102"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": false,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "https://webchat.cornelio.app"
      ]
    },
    "nodes": {
      "denyCommands": [
        "canvas.present",
        "canvas.hide",
        "canvas.navigate",
        "canvas.eval",
        "canvas.snapshot",
        "canvas.a2ui.push",
        "canvas.a2ui.pushJSONL",
        "canvas.a2ui.reset"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true
      }
    },
    "sessions": {
      "visibility": "all"
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "whatsapp": {
      "selfChatMode": false,
      "dmPolicy": "pairing",
      "allowFrom": [
        "+50672516680"
      ],
      "enabled": true
    },
    "telegram": {
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "skills": {
    "entries": {
      "sag": {
