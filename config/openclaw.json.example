{
  "agents": {
    "list": [
      {
        "id": "cornelio",
        "name": "Cornelio - CEO Virtual",
        "workspace": "/root/.openclaw/workspace",
        "agentDir": "/root/.openclaw/agents/cornelio/agent",
        "default": true,
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "read",
            "write",
            "edit",
            "exec",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "sessions_spawn",
            "subagents",
            "agentId",
            "web_search",
            "web_fetch",
            "memory_search",
            "memory_get",
            "tts",
            "image",
            "process",
            "sessions_yield"
          ]
        }
      },
      {
        "id": "magnum",
        "name": "Magnum - Brazo Derecho",
        "workspace": "/root/.openclaw/workspace-magnum",
        "agentDir": "/root/.openclaw/agents/magnum/agent",
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "read",
            "write",
            "edit",
            "exec",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "sessions_spawn",
            "subagents",
            "agentId",
            "web_search",
            "web_fetch",
            "memory_search",
            "memory_get",
            "tts",
            "image",
            "process"
          ]
        }
      }
    ],
